    "bucket_minimum_counts": {
      "resource_pressure_misplay": 2,
      "low_score_survival": 2
    },
    "bucket_seed_caps": {
      "risk_undercommit": 2,
      "resource_pressure_misplay": 2,
      "low_score_survival": 2
    },
    "slice_sampling_weights": {
      "slice_action_type:play": 1.18,
      "slice_action_type:shop": 1.34,
      "slice_resource_pressure:high": 1.4,
      "slice_resource_pressure:low": 0.96,
      "slice_resource_pressure:medium": 1.1,
      "slice_stage:early": 1.08
