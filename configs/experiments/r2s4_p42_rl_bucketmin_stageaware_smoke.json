{
  "schema": "p42_ppo_lite_config_v1",
  "output_artifacts_root": "docs/artifacts/research/r2s4_training",
  "curriculum_config": "configs/experiments/r2s4_p44_curriculum_bucketmin_stageaware.yaml",
  "seeds": [
    "AAAAAAA",
    "BBBBBBB",
    "CCCCCCC",
    "DDDDDDD"
  ],
  "env": {
    "backend": "sim",
