{
  "schema": "p22_experiment_config_v1",
  "budget": {
    "max_wall_time_minutes": 120,
    "max_episodes": 500,
    "max_seeds": 12,
    "max_concurrent_workers": 1
  },
  "seeds": {
    "base_seed": "P22BASE",
    "regression_fixed": [
      "AAAAAAA",
      "BBBBBBB",
      "CCCCCCC",
      "DDDDDDD",
      "EEEEEEE",
      "FFFFFFF",
      "GGGGGGG",
      "HHHHHHH"
    ],
    "extra_random": 4
  },
  "seed_policy": {
    "version": "p34.p22.v1",
    "base_seed": "P22BASE",
    "regression_smoke": [
      "AAAAAAA",
      "BBBBBBB",
      "CCCCCCC",
      "DDDDDDD"
    ],
    "train_default": [
      "AAAAAAA",
      "BBBBBBB",
      "CCCCCCC",
      "DDDDDDD",
      "EEEEEEE",
      "FFFFFFF",
      "GGGGGGG",
      "HHHHHHH"
    ],
    "eval_default": [
      "AAAAAAA",
      "BBBBBBB",
      "CCCCCCC",
      "DDDDDDD",
      "EEEEEEE",
      "FFFFFFF"
    ],
    "nightly_extra_random": 4
  },
  "matrix": [
    {
      "id": "quick_baseline",
      "name": "quick_baseline",
      "backend": "sim",
      "policy": "baseline",
      "seed_mode": "regression_fixed",
      "seed_set_name": "regression_smoke",
      "gate_flag": "RunFast",
      "stages": {
        "sanity": true,
        "gate": true,
        "dataset": false,
        "train": false,
        "eval": true
      },
      "eval": {
        "mode": "synthetic",
        "primary_metric_bias": 0.0
      }
    },
    {
      "id": "quick_candidate",
      "name": "quick_candidate",
      "backend": "sim",
      "policy": "candidate",
      "seed_mode": "nightly",
      "seed_set_name": "eval_default",
      "gate_flag": "RunFast",
      "stages": {
        "sanity": true,
        "gate": true,
        "dataset": false,
        "train": false,
        "eval": true
      },
      "eval": {
        "mode": "synthetic",
        "primary_metric_bias": 0.03
      }
    },
    {
      "id": "quick_selfsup_pretrain",
      "name": "quick_selfsup_pretrain",
      "backend": "sim",
      "policy": "selfsup",
      "experiment_type": "selfsup_pretrain",
      "seed_mode": "regression_fixed",
      "seed_set_name": "contract_regression",
      "seeds": [
        "AAAAAAA",
        "BBBBBBB",
        "CCCCCCC"
      ],
      "gate_flag": "RunFast",
      "modes": {
        "quick": true,
        "gate": true,
        "nightly": true
      },
      "stages": {
        "sanity": true,
        "gate": false,
        "dataset": false,
        "train": false,
        "eval": true
      },
      "sanity_compile": [
        "trainer/data/trajectory.py",
        "trainer/models/selfsup_encoder.py",
        "trainer/selfsup_train.py"
      ],
      "eval": {
        "mode": "selfsup",
        "config": "configs/experiments/p31_selfsup.yaml",
        "max_steps": 80
      }
    },
    {
      "id": "quick_selfsup_p33",
      "name": "quick_selfsup_p33",
      "backend": "sim",
      "policy": "selfsup_p33",
      "experiment_type": "selfsup_p33",
      "seed_mode": "regression_fixed",
      "seed_set_name": "contract_regression",
      "seeds": [
        "AAAAAAA",
        "BBBBBBB",
        "CCCCCCC"
      ],
      "gate_flag": "RunFast",
      "modes": {
        "quick": true,
        "gate": true,
        "nightly": true
      },
      "stages": {
        "sanity": true,
        "gate": false,
        "dataset": false,
        "train": false,
        "eval": true
      },
      "sanity_compile": [
        "trainer/self_supervised/datasets.py",
        "trainer/self_supervised/models.py",
        "trainer/self_supervised/train.py",
        "trainer/experiments/selfsupervised_p33.py"
      ],
      "eval": {
        "mode": "selfsup_p33",
        "config": "configs/experiments/p33_selfsup.yaml",
        "max_samples": 240
      }
    },
    {
      "id": "quick_selfsup_future_value",
      "name": "quick_selfsup_future_value",
      "backend": "sim",
      "policy": "selfsup_p36_future",
      "experiment_type": "selfsup_future_value",
      "seed_mode": "regression_fixed",
      "seed_set_name": "contract_regression",
      "seeds": [
        "AAAAAAA",
        "BBBBBBB",
        "CCCCCCC"
      ],
      "gate_flag": "RunFast",
      "modes": {
        "quick": true,
        "gate": true,
        "nightly": true
      },
      "stages": {
        "sanity": true,
        "gate": false,
        "dataset": false,
        "train": false,
        "eval": true
      },
      "sanity_compile": [
        "trainer/selfsup/data.py",
        "trainer/selfsup/tasks.py",
        "trainer/selfsup/train_future_value.py"
      ],
      "eval": {
        "mode": "selfsup_future_value",
        "config": "configs/experiments/p36_selfsup_future_value.yaml",
        "max_samples": 220
      }
    },
    {
      "id": "quick_selfsup_action_type",
      "name": "quick_selfsup_action_type",
      "backend": "sim",
      "policy": "selfsup_p36_action",
      "experiment_type": "selfsup_action_type",
      "seed_mode": "regression_fixed",
      "seed_set_name": "contract_regression",
      "seeds": [
        "AAAAAAA",
        "BBBBBBB",
        "CCCCCCC"
      ],
      "gate_flag": "RunFast",
      "modes": {
        "quick": true,
        "gate": true,
        "nightly": true
      },
      "stages": {
        "sanity": true,
        "gate": false,
        "dataset": false,
        "train": false,
        "eval": true
      },
      "sanity_compile": [
        "trainer/selfsup/data.py",
        "trainer/selfsup/tasks.py",
        "trainer/selfsup/train_action_type.py"
      ],
      "eval": {
        "mode": "selfsup_action_type",
        "config": "configs/experiments/p36_selfsup_action_type.yaml",
        "max_samples": 220
      }
    }
  ],
  "evaluation": {
    "primary_metric": "score",
    "gates": {
      "baseline_gate": "RunFast"
    },
    "promotion": {
      "min_delta": 0.01,
      "require_all_gates_pass": true
    }
  }
}
