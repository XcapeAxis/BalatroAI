{
  "schema": "p22_experiment_config_v1",
  "budget": {
    "max_wall_time_minutes": 120,
    "max_episodes": 500,
    "max_seeds": 12,
    "max_concurrent_workers": 1
  },
  "seeds": {
    "base_seed": "P22BASE",
    "regression_fixed": [
      "AAAAAAA",
      "BBBBBBB",
      "CCCCCCC",
      "DDDDDDD",
      "EEEEEEE",
      "FFFFFFF",
      "GGGGGGG",
      "HHHHHHH"
    ],
    "extra_random": 4
  },
  "matrix": [
    {
      "id": "quick_baseline",
      "name": "quick_baseline",
      "backend": "sim",
      "policy": "baseline",
      "seed_mode": "regression_fixed",
      "gate_flag": "RunFast",
      "stages": {
        "sanity": true,
        "gate": true,
        "dataset": false,
        "train": false,
        "eval": true
      },
      "eval": {
        "mode": "synthetic",
        "primary_metric_bias": 0.0
      }
    },
    {
      "id": "quick_candidate",
      "name": "quick_candidate",
      "backend": "sim",
      "policy": "candidate",
      "seed_mode": "nightly",
      "gate_flag": "RunFast",
      "stages": {
        "sanity": true,
        "gate": true,
        "dataset": false,
        "train": false,
        "eval": true
      },
      "eval": {
        "mode": "synthetic",
        "primary_metric_bias": 0.03
      }
    },
    {
      "id": "quick_selfsup_pretrain",
      "name": "quick_selfsup_pretrain",
      "backend": "sim",
      "policy": "selfsup",
      "experiment_type": "selfsup_pretrain",
      "seed_mode": "regression_fixed",
      "seed_set_name": "contract_regression",
      "seeds": [
        "AAAAAAA",
        "BBBBBBB",
        "CCCCCCC"
      ],
      "gate_flag": "RunFast",
      "modes": {
        "quick": true,
        "gate": true,
        "nightly": true
      },
      "stages": {
        "sanity": true,
        "gate": false,
        "dataset": false,
        "train": false,
        "eval": true
      },
      "sanity_compile": [
        "trainer/data/trajectory.py",
        "trainer/models/selfsup_encoder.py",
        "trainer/selfsup_train.py"
      ],
      "eval": {
        "mode": "selfsup",
        "config": "configs/experiments/p31_selfsup.yaml",
        "max_steps": 80
      }
    }
  ],
  "evaluation": {
    "primary_metric": "score",
    "gates": {
      "baseline_gate": "RunFast"
    },
    "promotion": {
      "min_delta": 0.01,
      "require_all_gates_pass": true
    }
  }
}
