      "shop_or_economy_misallocation": 1.6,
      "discard_mismanagement": 1.1,
      "position_sensitive_misplay": 1.26,
      "stateful_joker_misplay": 1.24,
      "low_score_survival": 1.12,
      "risk_undercommit": 0.82,
      "early_collapse": 0.76
    },
    "bucket_quota_caps": {
      "resource_pressure_misplay": 6,
      "shop_or_economy_misallocation": 6,
      "discard_mismanagement": 4,
      "position_sensitive_misplay": 4,
      "stateful_joker_misplay": 4,
      "low_score_survival": 5,
      "risk_undercommit": 5,
      "early_collapse": 4
    },
    "bucket_minimum_counts": {
      "resource_pressure_misplay": 2,
      "shop_or_economy_misallocation": 2,
      "low_score_survival": 1
    },
    "source_type_sampling_weights": {
      "arena_compound_slice_seed": 1.84,
      "arena_candidate_slice_seed": 1.72,
      "arena_slice_gap_seed": 1.14,
      "arena_failure_mining": 0.86
    },
    "source_type_quota_caps": {
      "arena_compound_slice_seed": 4,
      "arena_candidate_slice_seed": 5,
      "arena_slice_gap_seed": 4,
      "arena_failure_mining": 5
    },
    "slice_sampling_weights": {
      "slice_action_type:shop": 1.58,
      "slice_action_type:discard": 1.04,
      "slice_resource_pressure:high": 1.5,
      "slice_resource_pressure:medium": 1.18,
      "slice_stage:early": 0.98
    },
    "slice_minimum_counts": {
      "slice_action_type:shop": 2,
      "slice_resource_pressure:high": 2
    },
    "slice_quota_caps": {
      "slice_action_type:shop": 6,
      "slice_action_type:discard": 6,
      "slice_resource_pressure:high": 8
    },
    "risk_tag_sampling_weights": {
      "resource_tight": 1.34,
      "low_score_tail": 1.1,
      "early_collapse": 0.8
    },
    "risk_tag_quota_caps": {
      "resource_tight": 6,
      "low_score_tail": 5,
      "early_collapse": 4
    }
  },
  "self_imitation": {
    "enabled": false,
    "replay_ratio": 0.0
  },
  "train": {
    "ppo_epochs": 2,
    "minibatch_size": 64,
    "clip_range": 0.2,
    "gamma": 0.99,
    "gae_lambda": 0.95,
    "entropy_coef": 0.01,
    "value_coef": 0.5,
    "lr": 0.00025,
    "grad_clip_norm": 0.5,
    "normalize_advantage": true,
    "max_updates": 3,
    "invalid_action_warn_threshold": 0.12,
    "max_kl_warn": 0.2,
    "nan_fail_fast": true
