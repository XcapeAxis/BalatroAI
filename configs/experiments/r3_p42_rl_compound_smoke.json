{
  "schema": "p42_ppo_lite_config_v1",
  "output_artifacts_root": "docs/artifacts/research/r3_training",
  "curriculum_config": "configs/experiments/r3_p44_curriculum_sliceaware.yaml",
  "seeds": [
    "AAAAAAA",
    "BBBBBBB",
    "CCCCCCC",
    "DDDDDDD"
  ],
  "env": {
    "backend": "sim",
    "timeout_sec": 8.0,
    "max_steps_per_episode": 240,
    "max_auto_steps": 8,
    "max_ante": 0,
    "auto_advance": true,
    "reward": {
      "score_delta_weight": 0.98,
      "survival_bonus": 0.05,
      "terminal_win_bonus": 0.8,
      "terminal_loss_penalty": 0.8,
      "invalid_action_penalty": 0.12,
      "clip_abs": 2.5,
      "penalize_requested_invalid": true,
      "invalid_action_mode": "fallback_first_legal"
    }
  },
  "rollout": {
    "episodes_per_seed": 6,
    "max_steps_per_episode": 160,
    "total_steps_cap": 2200,
    "early_stop_invalid_rate": 0.35,
    "min_steps_before_early_stop": 64
  },
  "evaluation": {
    "seeds": [
      "AAAAAAA",
      "BBBBBBB",
      "CCCCCCC",
      "DDDDDDD"
    ],
    "episodes_per_seed": 2,
    "max_steps_per_episode": 180,
    "greedy": true,
    "out_root": "docs/artifacts/research/r3_eval"
  },
  "diagnostics": {
    "out_root": "docs/artifacts/research/r3_diagnostics",
    "action_topk": 16
  },
  "hard_case_sampling": {
    "enabled": true,
    "failure_pack_manifest": "",
    "max_failure_cases": 96,
    "max_failure_seeds": 10,
    "seed_replay_factor": 4,
    "include_base_seed": true,
    "preserve_seed_identity": true,
    "prioritize_failure_types": [
