{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "P22 Experiment Config",
  "type": "object",
  "required": ["budget", "seeds", "matrix", "evaluation"],
  "properties": {
    "budget": {
      "type": "object",
      "properties": {
        "max_wall_time_minutes": { "type": "integer", "minimum": 1 },
        "max_episodes": { "type": "integer", "minimum": 1 },
        "max_seeds": { "type": "integer", "minimum": 1 },
        "max_concurrent_workers": { "type": "integer", "minimum": 1 }
      }
    },
    "seeds": {
      "type": "object",
      "required": ["regression_fixed"],
      "properties": {
        "base_seed": { "type": "string" },
        "regression_fixed": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "extra_random": { "type": "integer", "minimum": 0 }
      }
    },
    "matrix": {
      "type": "array",
      "items": { "type": "object" }
    },
    "evaluation": {
      "type": "object",
      "properties": {
        "primary_metric": { "type": "string" }
      }
    }
  }
}

