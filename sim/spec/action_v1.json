{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sim/spec/action_v1.json",
  "title": "Action v1",
  "type": "object",
  "required": ["schema_version", "phase", "action_type"],
  "properties": {
    "schema_version": {"const": "action_v1"},
    "phase": {"type": "string"},
    "action_type": {
      "type": "string",
      "enum": [
        "PLAY",
        "DISCARD",
        "SELECT",
        "CASH_OUT",
        "NEXT_ROUND",
        "START",
        "WAIT",
        "MENU",
        "SKIP",
        "SHOP_REROLL",
        "REROLL",
        "SHOP_BUY",
        "BUY",
        "PACK_OPEN",
        "PACK",
        "SELL",
        "CONSUMABLE_USE",
        "USE",
        "REORDER_HAND",
        "REORDER_JOKERS",
        "MOVE_HAND_CARD",
        "MOVE_JOKER",
        "SWAP_HAND_CARD",
        "SWAP_JOKER",
        "SWAP_HAND_CARDS",
        "SWAP_JOKERS"
      ]
    },
    "indices": {
      "type": "array",
      "items": {"type": "integer", "minimum": 0},
      "maxItems": 5,
      "uniqueItems": true
    },
    "index": {"type": "integer", "minimum": 0},
    "seed": {"type": "string"},
    "params": {"type": "object"},
    "index_base": {"type": "integer", "enum": [0, 1]},
    "permutation": {
      "type": "array",
      "items": {"type": "integer", "minimum": 0},
      "uniqueItems": true
    },
    "src_index": {"type": "integer", "minimum": 0},
    "dst_index": {"type": "integer", "minimum": 0},
    "from_index": {"type": "integer", "minimum": 0},
    "to_index": {"type": "integer", "minimum": 0},
    "i": {"type": "integer", "minimum": 0},
    "j": {"type": "integer", "minimum": 0},
    "kind": {"type": "string"},
    "key": {"type": "string"},
    "cards": {
      "type": "array",
      "items": {"type": "integer", "minimum": 0},
      "uniqueItems": true
    },
    "hand_indices": {
      "type": "array",
      "items": {"type": "integer", "minimum": 0},
      "uniqueItems": true
    },
    "shop_index": {"type": "integer", "minimum": 0},
    "pack_index": {"type": "integer", "minimum": 0},
    "choice_index": {"type": "integer", "minimum": 0},
    "voucher_index": {"type": "integer", "minimum": 0},
    "consumable_index": {"type": "integer", "minimum": 0},
    "joker_index": {"type": "integer", "minimum": 0},
    "targets": {
      "type": "array",
      "items": {"type": "integer", "minimum": 0},
      "uniqueItems": true
    },
    "target_side": {
      "type": "string",
      "enum": ["left", "right", "none"]
    }
  }
}
