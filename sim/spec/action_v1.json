{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sim/spec/action_v1.json",
  "title": "Action v1",
  "type": "object",
  "required": ["schema_version", "phase", "action_type"],
  "properties": {
    "schema_version": {"const": "action_v1"},
    "phase": {"type": "string"},
    "action_type": {
      "type": "string",
      "enum": [
        "PLAY",
        "DISCARD",
        "SELECT",
        "CASH_OUT",
        "NEXT_ROUND",
        "START",
        "WAIT",
        "MENU",
        "SKIP",
        "REROLL",
        "BUY",
        "PACK",
        "SELL",
        "USE",
        "REORDER_HAND",
        "REORDER_JOKERS",
        "SWAP_HAND_CARDS",
        "SWAP_JOKERS"
      ]
    },
    "indices": {
      "type": "array",
      "items": {"type": "integer", "minimum": 0},
      "maxItems": 5,
      "uniqueItems": true
    },
    "index": {"type": "integer", "minimum": 0},
    "seed": {"type": "string"},
    "params": {"type": "object"},
    "permutation": {
      "type": "array",
      "items": {"type": "integer", "minimum": 0},
      "uniqueItems": true
    },
    "i": {"type": "integer", "minimum": 0},
    "j": {"type": "integer", "minimum": 0},
    "targets": {
      "type": "array",
      "items": {"type": "integer", "minimum": 0},
      "uniqueItems": true
    },
    "target_side": {
      "type": "string",
      "enum": ["left", "right", "none"]
    }
  }
}
